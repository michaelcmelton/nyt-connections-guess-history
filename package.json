{
  "name": "connections-guess-history",
  "version": "1.0.0",
  "description": "Chrome extension for viewing NYT Connections guess history",
  "main": "index.js",
  "scripts": {
    "dev": "webpack serve --mode development",
    "build": "webpack --mode production",
    "build:win": "webpack --mode production && mkdir -p /mnt/c/Users/Mike/nyt-extension && cp -r ~/projects/nyt-connections-guess-history/dist/* /mnt/c/Users/Mike/nyt-extension",
    "test": "jest --silent",
    "test:e2e": "npm run build && jest --config=jest.config.e2e.js",
    "lint": "eslint src/**/*.{ts,tsx}",
    "format": "prettier --write src/**/*.{ts,tsx}"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/chrome": "^0.0.260",
    "@types/jest": "^27.0.0",
    "@types/node": "^22.15.30",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "copy-webpack-plugin": "^12.0.2",
    "css-loader": "^6.10.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.33.2",
    "html-webpack-plugin": "^5.6.0",
    "jest": "^27.5.1",
    "jest-chrome": "^0.8.0",
    "jest-dom": "^4.0.0",
    "jest-puppeteer": "^6.0.0",
    "prettier": "^3.2.5",
    "puppeteer": "^18.0.0",
    "puppeteer-core": "^18.0.0",
    "style-loader": "^3.3.4",
    "ts-jest": "^27.0.0",
    "ts-loader": "^9.5.1",
    "typescript": "^4.9.5",
    "webpack": "^5.90.1",
    "webpack-cli": "^5.1.4",
    "webpack-dev-server": "^4.15.1"
  }
}
