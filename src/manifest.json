{
  "manifest_version": 3,
  "name": "Connections Guess History",
  "version": "1.0.0",
  "description": "View your guess history in NYT Connections",
  "permissions": ["storage", "activeTab"],
  "host_permissions": ["https://www.nytimes.com/games/connections*"],
  "action": {
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.nytimes.com/games/connections*"],
      "js": ["content.js"]
    }
  ]
} 